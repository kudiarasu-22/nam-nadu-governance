# Nam Nadu Backend — Environment Configuration

# Application
ENVIRONMENT=development
API_TITLE=Nam Nadu API
API_VERSION=1.0.0
API_DESCRIPTION=Citizens-Government Governance Platform for Tamil Nadu

# Database
# DATABASE_URL=sqlite:///./nam_nadu.db
DATABASE_URL=postgresql+psycopg://postgres:root@localhost:5432/nam_nadu

# JWT Authentication
SECRET_KEY=nam-nadu-dev-secret-change-in-production-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:3000","http://127.0.0.1:5173"]